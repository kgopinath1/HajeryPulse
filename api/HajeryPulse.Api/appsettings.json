{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ReportingDb": "Server=localhost;Database=HajeryPulse_Reporting;Integrated Security=true;Encrypt=False;TrustServerCertificate=true",
    "Redis": "localhost:6379"
  },
  "EntraId": {
    "Instance":   "https://login.microsoftonline.com/",
    "Domain":     "hajerygroup.onmicrosoft.com",
    "TenantId":   "YOUR_TENANT_ID",
    "ClientId":   "YOUR_API_CLIENT_ID",
    "Audience":   "api://hajerypulse-api",
    "CallbackPath": "/signin-oidc"
  },
  "Cache": {
    "DashboardTtlSeconds": 600,
    "InboxTtlSeconds":      30,
    "ListsTtlSeconds":     900
  }
}
